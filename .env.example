DATABASE_URL=postgresql://user:password@localhost:5432/redpulse
AUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Auth OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Reddit — lecture publique sans compte dev Reddit
# RedPulse utilise Arctic Shift (posts récents) + PullPush (archive).
# Aucune clé OAuth requise pour le scraping.
ARCTIC_SHIFT_API_URL=https://arctic-shift.photon-reddit.com
REDDIT_USER_AGENT=web:redpulse:1.0.0 (by /u/redpulse_app)
# Optionnel — uniquement pour publier/envoyer des DM via votre compte Reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REDIRECT_URI=http://localhost:3000/api/reddit/callback

# IA — modèle fixe : claude-haiku-4-5-20251001 (ne pas modifier)
ANTHROPIC_API_KEY=

# Chiffrement tokens Reddit (openssl rand -base64 32)
ENCRYPTION_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PRO=

# Optionnel
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RESEND_API_KEY=
