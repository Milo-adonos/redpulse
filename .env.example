DATABASE_URL=postgresql://user:password@localhost:5432/redpulse
AUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Auth OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Reddit app (https://www.reddit.com/prefs/apps — type "script")
# Requis si Reddit bloque le JSON public (403). Lecture seule côté serveur, pas de connexion compte utilisateur.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REDIRECT_URI=http://localhost:3000/api/reddit/callback
REDDIT_USER_AGENT=web:redpulse:1.0.0 (by /u/VOTRE_USERNAME_REDDIT)

# IA
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Chiffrement tokens Reddit (openssl rand -base64 32)
ENCRYPTION_KEY=

# Cron scrape job (Vercel Cron ou Railway — toutes les 15 min)
CRON_SECRET=generate-a-random-secret
# Scraper 24/7 intégré au serveur Next (Railway / local). Mettre false pour désactiver.
ENABLE_BACKGROUND_SCRAPER=true
# Intervalle en ms (défaut 900000 = 15 min)
SCRAPE_INTERVAL_MS=900000
# Max nouveaux messages Claude par équipe et par cycle
SCRAPE_MAX_REPLIES_PER_RUN=5
SCRAPE_MAX_WARMUP_PER_RUN=3

# Optionnel
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RESEND_API_KEY=
